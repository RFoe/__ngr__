#pragma once

#include <linux/io_uring.h>
#include <mutex>
#include <span>
#include <sys/eventfd.h>
#include <sys/mman.h>
#include <sys/syscall.h>
#include <sys/uio.h>
#include <unistd.h>

#include <atomic>
#include <bit>
#include <cassert>
#include <cerrno>
#include <chrono>
#include <coroutine>
#include <cstddef>
#include <cstdint>
#include <cstdlib>
#include <cstring>
#include <system_error>
#include <utility>

#include <asm-generic/int-ll64.h>

#include <__ngr/__core/__atomic_intrusive_queue.hpp>
#include <__ngr/__core/__file_descriptor.hpp>
#include <__ngr/__core/__intrusive_heap.hpp>
#include <__ngr/__core/__intrusive_queue.hpp>
#include <__ngr/__core/__memory_mapped_region.hpp>
#include <__ngr/__core/__thread_scheduler.hpp>

// A pure io_uring context: the submission/completion ring machinery distilled
// from the stdexec io_uring scheduler, with all sender/receiver plumbing
// removed. It exposes only primitives -- submission, completion reaping, and
// resource registration -- so that an external coroutine executor can drive the
// loop. Awaitable operations live in <__ngr/__core/__io_uring_ops.hpp>.
//
// Threading model: the driver members (`_M_drain_io_task`, `_M_complete`,
// `_M_run_once`) must be called from the single thread that drives the ring;
// `_M_submit` and `_M_wakeup` are safe to call from any thread.

// NOLINTBEGIN(*-vararg, *-special-member-functions)
namespace __ngr::inline __v0::__core {

[[__gnu__::__always_inline__, __gnu__::__artificial__]]
inline void _S_throw_error_code_if(const bool __cond, const int __ec) {
    if (__cond) [[__unlikely__]] {
        throw std::system_error(__ec, std::system_category());
    }
}

inline auto _S_io_uring_setup(unsigned __entries, ::io_uring_params &__params)
    -> __file_descriptor {
    const int __rc =
        static_cast<int>(::syscall(__NR_io_uring_setup, __entries, &__params));
    _S_throw_error_code_if(__rc < 0, -__rc);
    return __file_descriptor{__rc};
}

inline auto _S_io_uring_enter(
    int __ring_fd, unsigned int __to_submit, unsigned int __min_complete,
    unsigned int __flags) -> int {
    const int __rc = static_cast<int>(::syscall(
        __NR_io_uring_enter, __ring_fd, __to_submit, __min_complete, __flags,
        nullptr, 0));
    if (__rc == -1) [[__unlikely__]] { return -errno; }
    return __rc;
}

// io_uring_enter with an extended argument (IORING_ENTER_EXT_ARG). The argument
// carries a relative wait timeout in `ts`, letting a single io_uring_enter both
// reap completions and bound the wait by the earliest pending timer -- no
// IORING_OP_TIMEOUT SQE is registered with the kernel.
#ifndef IORING_ENTER_EXT_ARG
    #define IORING_ENTER_EXT_ARG (1U << 3)
#endif

[[__gnu__::__always_inline__, __gnu__::__artificial__, __nodiscard__]]
inline auto _S_duration_to_timespec(std::chrono::nanoseconds __dur) noexcept
    -> __kernel_timespec {
    auto __sec = std::chrono::duration_cast<std::chrono::seconds>(__dur);
    __dur -= __sec;
    __sec = (std::max)(__sec, std::chrono::seconds{0});
    __dur = std::clamp(
        __dur, std::chrono::nanoseconds{0},
        std::chrono::nanoseconds{999'999'999});
    return __kernel_timespec{.tv_sec = __sec.count(), .tv_nsec = __dur.count()};
}

[[__gnu__::__always_inline__, __gnu__::__artificial__, __nodiscard__]]
inline auto _S_io_uring_enter(
    int __ring_fd, unsigned int __to_submit, unsigned int __min_complete,
    unsigned int __flags, void *__arg, std::size_t __argsz) -> int {
    const int __rc = static_cast<int>(::syscall(
        __NR_io_uring_enter, __ring_fd, __to_submit, __min_complete, __flags,
        __arg, __argsz));
    if (__rc == -1) [[__unlikely__]] { return -errno; }
    return __rc;
}

[[__gnu__::__always_inline__, __gnu__::__artificial__, __nodiscard__]]
inline auto _S_io_uring_register(
    int __ring_fd, unsigned __opcode, void *__arg, unsigned __nr) -> int {
    const int __rc = static_cast<int>(
        ::syscall(__NR_io_uring_register, __ring_fd, __opcode, __arg, __nr));
    if (__rc == -1) [[__unlikely__]] { return -errno; }
    return __rc;
}

[[__gnu__::__always_inline__, __gnu__::__artificial__, __nodiscard__]]
inline auto _S_mmap(int __fd, ::off_t __offset, std::size_t __size)
    -> __memory_mapped_region {
    void *__ptr = ::mmap(
        nullptr, __size, PROT_READ | PROT_WRITE, MAP_SHARED | MAP_POPULATE,
        __fd, __offset);
    _S_throw_error_code_if(__ptr == MAP_FAILED, errno);
    return __memory_mapped_region{__ptr, __size};
}

[[__gnu__::__always_inline__, __gnu__::__artificial__, __nodiscard__]]
inline constexpr auto _S_umin(__u32 __a, __u32 __b) noexcept -> __u32 {
    return __a < __b ? __a : __b;
}

[[__gnu__::__always_inline__, __gnu__::__artificial__, __nodiscard__]]
inline constexpr auto _S_umax(__u32 __a, __u32 __b) noexcept -> __u32 {
    return __a < __b ? __b : __a;
}

// NOLINTBEGIN(cppcoreguidelines-pro-bounds-pointer-arithmetic)
template <typename _Ty>
[[__gnu__::__always_inline__, __gnu__::__artificial__, __nodiscard__]]
inline auto _S_at_offset_as(void *__base, __u32 __offset) noexcept -> _Ty {
    return reinterpret_cast<_Ty>(static_cast<std::byte *>(__base) + __offset);
}
// NOLINTEND(cppcoreguidelines-pro-bounds-pointer-arithmetic)

struct __io_task;

// Each io operation provides the following interface, mirroring the original
// stdexec layout so that the address-stable, intrusively queued task model is
// preserved verbatim.
struct __io_task_vtable {
    void (*__submit_)(__io_task *, ::io_uring_sqe &) noexcept;
    // Called once the operation completes with its io_uring_cqe.
    void (*__complete_)(__io_task *, const ::io_uring_cqe &) noexcept;
};

// Base for every operation. The address must be stable for the whole lifetime
// of the operation -- guaranteed here because operations live inside
// heap-allocated coroutine frames.
//
// `__next_`/`__vtable_` drive the io_uring submission/completion phase. Once an
// operation is ready to resume its coroutine the same node is handed to the
// executor as the work item: `__execute_` is the executor entry point (matching
// experimental::execution::task_base::execute_), invoked off the ring-driver
// thread. `__next_` is reused as the executor queue link -- the two phases
// never overlap in time (an op is in the io queues, then in the SQ ring, then
// free to enter the executor queue).
struct __io_task : __generic_task {
    const __io_task_vtable *__vtable_;

    explicit __io_task(const __io_task_vtable &__vtable) noexcept
        : __vtable_(&__vtable) {}

    __io_task(const __io_task &)                     = delete;
    auto operator=(const __io_task &) -> __io_task & = delete;
};

using __task_queue        = __intrusive_queue<&__generic_task::__next_>;
using __atomic_task_queue = __atomic_intrusive_queue<&__generic_task::__next_>;

// ---------------------------------------------------------------------------
// Timer task: a node in the context's timer heap. Timers are not registered
// with the kernel individually; they live in an intrusive heap and only the
// earliest deadline (`heap.top`) bounds each io_uring_enter wait. Cancellation
// is a pure heap erase, so the common "armed then cancelled" timer never
// touches the kernel at all.
//
// The same node type carries both a `schedule` request (insert into the heap)
// and a `cancel` request (erase `__target_` from the heap); both are delivered
// to the driver thread through the context's atomic timer queue.
// ---------------------------------------------------------------------------
struct __generic_timer_task : __generic_task {
    enum class __command : unsigned char { __schedule, __cancel };
    __command __command_ = __command::__schedule;
};
struct __timer_task : __generic_timer_task {
    using __clock      = std::chrono::steady_clock;
    using __time_point = __clock::time_point;

    // Heap key: deadline, tie-broken by insertion sequence so the heap order is
    // stable for equal deadlines.
    struct __time_sequence {
        __time_point __deadline_{};
        std::size_t  __seq_{};

        friend auto operator<(
            __time_sequence const &__a, __time_sequence const &__b) noexcept
            -> bool {
            return __a.__deadline_ < __b.__deadline_ ||
                   (!(__b.__deadline_ < __a.__deadline_) &&
                    __a.__seq_ < __b.__seq_);
        }
    };

    __timer_task   *__hprev_  = nullptr; // heap parent
    __timer_task   *__hleft_  = nullptr; // heap children
    __timer_task   *__hright_ = nullptr;
    __time_sequence __key_{};

    // schedule: invoked when the deadline elapses.
    void (*__fire_)(__timer_task *) noexcept = nullptr;
};
struct __cancel_timer_task : __generic_timer_task {
    __timer_task *__target_ = nullptr;
};
using __timer_heap = __intrusive_heap<
    __timer_task, &__timer_task::__key_, &__timer_task::__hprev_,
    &__timer_task::__hleft_, &__timer_task::__hright_>;

struct __submission_result {
    __u32        __n_submitted_ = 0;
    __task_queue __pending_{};
};

// ---------------------------------------------------------------------------
// Submission queue
// ---------------------------------------------------------------------------
class __submission_queue {
    std::atomic_ref<__u32>    __head_;
    std::atomic_ref<__u32>    __tail_;
    std::span<__u32>          __array_;
    std::span<::io_uring_sqe> __entries_;
    __u32                     __mask_;
    __u32                     __n_total_slots_;

  public:
    explicit __submission_queue(
        const __memory_mapped_region &__region,
        const __memory_mapped_region &__sqes_region,
        const ::io_uring_params      &__params) noexcept
        : __head_{
              *_S_at_offset_as<__u32 *>(__region.__ptr_, __params.sq_off.head)},
          __tail_{
              *_S_at_offset_as<__u32 *>(__region.__ptr_, __params.sq_off.tail)},
          __array_{
              _S_at_offset_as<__u32 *>(__region.__ptr_, __params.sq_off.array),
              __params.sq_entries},
          __entries_{
              static_cast<::io_uring_sqe *>(__sqes_region.__ptr_),
              __params.sq_entries},
          __mask_{*_S_at_offset_as<__u32 *>(
              __region.__ptr_, __params.sq_off.ring_mask)},
          __n_total_slots_{__params.sq_entries} {}

    // Submit as many tasks as fit into the ring. Ready tasks are routed to
    // `__ready`; the overflow stays in `__pending`. When `__is_stopped` is set,
    // only cancellation operations are actually submitted -- everything else is
    // completed inline with -ECANCELED.
    auto submit(__task_queue __tasks, __u32 __max_submissions) noexcept
        -> __submission_result {
        __u32       __tail = __tail_.load(std::memory_order_relaxed);
        __u32       __head = __head_.load(std::memory_order_acquire);
        const __u32 __n    = __tail - __head;
        assert(__n <= __n_total_slots_);
        __max_submissions = _S_umin(__max_submissions, __n_total_slots_ - __n);
        __submission_result __result{};
        while (!__tasks._M_empty() &&
               __result.__n_submitted_ < __max_submissions) {
            const __u32     __idx = __tail & __mask_;
            ::io_uring_sqe &__sqe = __entries_[__idx];
            auto *__op = static_cast<__io_task *>(__tasks._M_pop_front());
            __op->__vtable_->__submit_(__op, __sqe);
            __sqe.user_data = std::bit_cast<__u64>(__op);
            __array_[__idx] = __idx;
            ++__result.__n_submitted_;
            ++__tail;
        }
        __tail_.store(__tail, std::memory_order_release);
        while (!__tasks._M_empty()) {
            auto *__op = static_cast<__io_task *>(__tasks._M_pop_front());
            __result.__pending_._M_push_back(__op);
        }
        return __result;
    }
};

// ---------------------------------------------------------------------------
// Completion queue
// ---------------------------------------------------------------------------
class __completion_queue {
    std::atomic_ref<__u32> __head_;
    std::atomic_ref<__u32> __tail_;
    ::io_uring_cqe        *__entries_;
    __u32                  __mask_;

  public:
    explicit __completion_queue(
        const __memory_mapped_region &__region,
        const ::io_uring_params      &__params) noexcept
        : __head_{
              *_S_at_offset_as<__u32 *>(__region.__ptr_, __params.cq_off.head)},
          __tail_{
              *_S_at_offset_as<__u32 *>(__region.__ptr_, __params.cq_off.tail)},
          __entries_{_S_at_offset_as<::io_uring_cqe *>(
              __region.__ptr_, __params.cq_off.cqes)},
          __mask_{*_S_at_offset_as<__u32 *>(
              __region.__ptr_, __params.cq_off.ring_mask)} {}

    // Reap every available CQE, then complete any locally-ready tasks. Returns
    // the number of *ring* completions consumed (locally-ready tasks were never
    // submitted, so they are not counted against outstanding submissions).
    auto complete() noexcept -> int {
        __u32 __head  = __head_.load(std::memory_order_relaxed);
        __u32 __tail  = __tail_.load(std::memory_order_acquire);
        int   __count = 0;
        while (__head != __tail) {
            const __u32           __index = __head & __mask_;
            const ::io_uring_cqe &__cqe   = __entries_[__index];
            auto *__op = std::bit_cast<__io_task *>(__cqe.user_data);
            // user_data is null for fire-and-forget SQEs (none here) -- guard
            // anyway so a stray completion never dereferences garbage.
            if (__op != nullptr) [[__likely__]] {
                __op->__vtable_->__complete_(__op, __cqe);
            }
            ++__head;
            ++__count;
            __tail = __tail_.load(std::memory_order_acquire);
        }
        __head_.store(__head, std::memory_order_release);
        return __count;
    }
};

// ---------------------------------------------------------------------------
// Provided-buffer ring: a kernel-shared ring of receive buffers used by
// multishot recv (IOSQE_BUFFER_SELECT). The caller owns the backing storage;
// completed buffers are recycled with `_M_recycle`.
// ---------------------------------------------------------------------------
class __provided_buffer_ring {
  public:
    __provided_buffer_ring() = default;

    __provided_buffer_ring(const __provided_buffer_ring &) = delete;
    auto operator=(const __provided_buffer_ring &)
        -> __provided_buffer_ring & = delete;

    __provided_buffer_ring(__provided_buffer_ring &&__o) noexcept
        : __ring_{std::exchange(__o.__ring_, nullptr)},
          __base_{std::exchange(__o.__base_, nullptr)},
          __buf_size_{std::exchange(__o.__buf_size_, 0)},
          __entries_{std::exchange(__o.__entries_, 0)},
          __mask_{std::exchange(__o.__mask_, 0)},
          __bgid_{std::exchange(__o.__bgid_, 0)},
          __ring_fd_{std::exchange(__o.__ring_fd_, -1)} {}

    ~__provided_buffer_ring() noexcept { _M_reset(); }

    [[__nodiscard__]] auto _M_group_id() const noexcept -> __u16 {
        return __bgid_;
    }

    // Translate a completion's buffer id into the backing storage span.
    [[__nodiscard__]] auto _M_buffer(__u16 __bid) const noexcept -> void * {
        return static_cast<std::byte *>(__base_) +
               static_cast<std::size_t>(__bid) * __buf_size_;
    }

    [[__nodiscard__]] auto _M_buffer_size() const noexcept -> std::size_t {
        return __buf_size_;
    }

    // Hand a buffer back to the kernel after its data has been consumed.
    void _M_recycle(__u16 __bid) noexcept {
        const __u16     __tail = __ring_->tail;
        ::io_uring_buf &__b    = __ring_->bufs[__tail & __mask_];
        __b.addr               = std::bit_cast<__u64>(_M_buffer(__bid));
        __b.len                = static_cast<__u32>(__buf_size_);
        __b.bid                = __bid;
        // Publish: the kernel reads `tail` with acquire semantics.
        std::atomic_ref<__u16>{__ring_->tail}.store(
            static_cast<__u16>(__tail + 1), std::memory_order_release);
    }

  private:
    friend class __io_uring_dispatch;

    void _M_init(
        int __ring_fd, __u16 __bgid, void *__base, std::size_t __buf_size,
        __u16 __entries) {
        assert((__entries & (__entries - 1)) == 0 && "entries must be 2^n");
        const std::size_t __bytes =
            static_cast<std::size_t>(__entries) * sizeof(::io_uring_buf);
        void *__mem = nullptr;
        _S_throw_error_code_if(
            ::posix_memalign(&__mem, 4096, __bytes) != 0, ENOMEM);
        std::memset(__mem, 0, __bytes);

        __ring_     = static_cast<::io_uring_buf_ring *>(__mem);
        __base_     = __base;
        __buf_size_ = __buf_size;
        __entries_  = __entries;
        __mask_     = static_cast<__u16>(__entries - 1);
        __bgid_     = __bgid;
        __ring_fd_  = __ring_fd;

        ::io_uring_buf_reg __reg{};
        __reg.ring_addr    = std::bit_cast<__u64>(__mem);
        __reg.ring_entries = __entries;
        __reg.bgid         = __bgid;
        const int __rc     = _S_io_uring_register(
            __ring_fd, IORING_REGISTER_PBUF_RING, &__reg, 1);
        if (__rc < 0) {
            ::free(__mem);
            __ring_ = nullptr;
            _S_throw_error_code_if(true, -__rc);
        }
        __ring_->tail = 0;
        // Seed every buffer into the ring.
        for (__u16 __i = 0; __i < __entries; ++__i) { _M_recycle(__i); }
    }

    void _M_reset() noexcept {
        if (__ring_ != nullptr) {
            ::io_uring_buf_reg __reg{};
            __reg.bgid = __bgid_;
            (void)_S_io_uring_register(
                __ring_fd_, IORING_UNREGISTER_PBUF_RING, &__reg, 1);
            ::free(__ring_);
            __ring_ = nullptr;
        }
    }

    ::io_uring_buf_ring *__ring_     = nullptr;
    void                *__base_     = nullptr;
    std::size_t          __buf_size_ = 0;
    __u16                __entries_  = 0;
    __u16                __mask_     = 0;
    __u16                __bgid_     = 0;
    int                  __ring_fd_  = -1;
};

// ---------------------------------------------------------------------------
// Ring memory mapping (RAII base).
// ---------------------------------------------------------------------------
struct __io_uring_context_base {
    explicit __io_uring_context_base(unsigned __entries, unsigned __flags = 0)
        : __params_{_S_init_params(__flags)},
          __ring_fd_{_S_io_uring_setup(__entries, __params_)},
          __eventfd_{::eventfd(0, EFD_CLOEXEC)} {
        _S_throw_error_code_if(!__eventfd_, errno);
        std::size_t __sring_sz =
            __params_.sq_off.array + __params_.sq_entries * sizeof(unsigned);
        std::size_t __cring_sz = __params_.cq_off.cqes +
                                 __params_.cq_entries * sizeof(::io_uring_cqe);
        std::size_t __sqes_sz  = __params_.sq_entries * sizeof(::io_uring_sqe);
        if ((__params_.features & IORING_FEAT_SINGLE_MMAP) != 0U) {
            __sring_sz = _S_umax(
                static_cast<__u32>(__sring_sz), static_cast<__u32>(__cring_sz));
            __cring_sz = __sring_sz;
        }
        __submission_queue_region_ =
            _S_mmap(__ring_fd_.__fd_, IORING_OFF_SQ_RING, __sring_sz);
        __submission_queue_entries_ =
            _S_mmap(__ring_fd_.__fd_, IORING_OFF_SQES, __sqes_sz);
        if ((__params_.features & IORING_FEAT_SINGLE_MMAP) == 0U) {
            __completion_queue_region_ =
                _S_mmap(__ring_fd_.__fd_, IORING_OFF_CQ_RING, __cring_sz);
        }
    }

    __io_uring_context_base(const __io_uring_context_base &) = delete;
    auto operator=(const __io_uring_context_base &)
        -> __io_uring_context_base & = delete;

    static auto _S_init_params(unsigned __flags) noexcept -> ::io_uring_params {
        ::io_uring_params __params{};
#ifdef IORING_SETUP_SUBMIT_ALL
        __flags |= IORING_SETUP_SUBMIT_ALL;
#endif
        __params.flags = __flags;
        return __params;
    }

    __memory_mapped_region __submission_queue_region_{};
    __memory_mapped_region __completion_queue_region_{};
    __memory_mapped_region __submission_queue_entries_{};
    ::io_uring_params      __params_{};
    __file_descriptor      __ring_fd_{};
    __file_descriptor      __eventfd_{};
};

class __io_uring_dispatch;

// Self-rearming read on the eventfd. `_M_wakeup` writes the eventfd; the
// resulting completion interrupts a blocking io_uring_enter so cross-thread
// submissions are noticed promptly. It re-submits itself on completion.
struct __wakeup_operation : __io_task {
    __io_uring_dispatch *__context_;
    int                  __eventfd_;
    std::uint64_t        __buffer_ = 0;

    static auto __ready_(__io_task *) noexcept -> bool { return false; }

    static void __submit_(__io_task *__p, ::io_uring_sqe &__sqe) noexcept {
        auto &__self = *static_cast<__wakeup_operation *>(__p);
        __sqe        = ::io_uring_sqe{};
        __sqe.opcode = IORING_OP_READ;
        __sqe.fd     = __self.__eventfd_;
        __sqe.addr   = std::bit_cast<__u64>(&__self.__buffer_);
        __sqe.len    = sizeof(__self.__buffer_);
    }

    static void __complete_(__io_task *__p, const ::io_uring_cqe &) noexcept;

    static constexpr __io_task_vtable __vtable{&__submit_, &__complete_};

    __wakeup_operation(__io_uring_dispatch *__ctx, int __eventfd) noexcept
        : __io_task{__vtable}, __context_{__ctx}, __eventfd_{__eventfd} {}
};

// ---------------------------------------------------------------------------
// The context.
// ---------------------------------------------------------------------------
class __io_uring_dispatch : __io_uring_context_base {
  protected:
    // Constructed only through the templated __io_uring_context, which then
    // wires the dispatch hook via _M_set_dispatch_hook; a bare
    // __io_uring_dispatch would have a null dispatch hook.
    explicit __io_uring_dispatch(
        unsigned __entries = 1024, unsigned __flags = 0)
        : __io_uring_context_base(_S_umax(__entries, 2U), __flags),
          __completion_queue_{
              __completion_queue_region_ ? __completion_queue_region_
                                         : __submission_queue_region_,
              __params_},
          __submission_queue_{
              __submission_queue_region_, __submission_queue_entries_,
              __params_},
          __wakeup_operation_{this, __eventfd_.__fd_} {}

  public:
    // --- wakeup (thread-safe) ---------------------------------------------
    auto _M_try_wakeup() noexcept -> std::error_code {
        std::uint64_t __value = 1;
        if (::write(__eventfd_.__fd_, &__value, sizeof(__value)) == -1) {
            return {errno, std::system_category()};
        }
        return {};
    }

    void _M_wakeup() {
        if (auto __ec = _M_try_wakeup()) { throw std::system_error{__ec}; }
    }

    // Arm the eventfd wakeup read (idempotent). Call once, on the driver
    // thread, before blocking in `_M_run_once` if other threads will submit.
    void _M_arm_wakeup() noexcept {
        if (!__wakeup_armed_) {
            __wakeup_armed_ = true;
            __pending_._M_push_front(&__wakeup_operation_);
        }
    }

    // --- submission --------------------------------------------------------

    // Thread-safe submit from any thread; this is the only submission entry
    // point. The deferred-submit thunk of an awaiter routes through here too:
    // it may run on a foreign thread (the root coroutine is started off the
    // driver thread), so a driver-local push would race the driver's queues.
    //
    // After enqueuing we publish a notification through the run-state. If the
    // driver is blocked in `io_uring_enter` (`_S_sleep`), poke the eventfd to
    // break it out; otherwise we only flip it to `_S_notify`, which makes the
    // driver skip its next blocking wait so the request is folded in promptly.
    void _M_submit(__io_task *__op) noexcept {
        __requests_._M_push_front(__op);
        if (__state_.exchange(_Sg::_S_notify, std::memory_order_acq_rel) ==
            _Sg::_S_sleep) {
            // best-effort: a failed wakeup only delays noticing the request.
            { std::lock_guard __lock{__fence_mut_}; }
            _M_wakeup();
        }
    }

    // Thread-safe submission of a timer command (schedule or cancel). The
    // driver folds it into the timer heap on its next iteration. Uses the same
    // notify protocol as `_M_submit` so a newly-armed earlier timer promptly
    // re-bounds the driver's wait.
    void _M_submit_timer(__generic_timer_task *__op) noexcept {
        __timer_requests_._M_push_front(__op);
        if (__state_.exchange(_Sg::_S_notify, std::memory_order_acq_rel) ==
            _Sg::_S_sleep) {
            // best-effort: a failed wakeup only delays noticing the request.
            { std::lock_guard __lock{__fence_mut_}; }
            _M_wakeup();
        }
    }

    // --- driving the loop --------------------------------------------------

    // Fold cross-thread requests into the local pending queue, then push as
    // many pending tasks into the SQ as will fit, completing locally-ready
    // tasks inline. Does not enter the kernel. Driver thread only.
    void _M_drain_io_task() noexcept {
        __n_total_submitted_ -= __completion_queue_.complete();
        assert(__n_total_submitted_ >= 0);
        __u32 __max =
            __params_.cq_entries - static_cast<__u32>(__n_total_submitted_);
        __pending_._M_append(__requests_._M_pop_swap_reversed());
        __submission_result __result = __submission_queue_.submit(
            static_cast<__task_queue &&>(__pending_), __max);
        __n_total_submitted_ += __result.__n_submitted_;
        __n_newly_submitted_ += __result.__n_submitted_;
        __pending_ = static_cast<__task_queue &&>(__result.__pending_);
    }

    // Reap completed CQEs, resuming coroutines. Driver thread only. Returns the
    // number of completions consumed.
    auto _M_complete() noexcept -> int {
        const int __n = __completion_queue_.complete();
        __n_total_submitted_ -= __n;
        assert(__n_total_submitted_ >= 0);
        return __n;
    }

    // Fold cross-thread timer commands into the heap. Driver thread only.
    void _M_drain_generic_timer_task() noexcept {
        __task_queue __cmds = __timer_requests_._M_pop_swap_reversed();
        while (!__cmds._M_empty()) {
            auto *__op =
                static_cast<__generic_timer_task *>(__cmds._M_pop_front());
            if (__op->__command_ == __timer_task::__command::__schedule) {
                __timer_heap_._M_push(static_cast<__timer_task *>(__op));
            } else {
                // Cancel: erase the target if it is still queued, signalling it
                // as stopped, then complete the cancel command itself.
                __timer_task *__target =
                    static_cast<__cancel_timer_task *>(__op)->__target_;
                __timer_heap_._M_try_erase(__target);
                (*__target->__fire_)(__target);
            }
        }
    }

    // Resume every timer whose deadline has elapsed. Driver thread only.
    void _M_fire_expired_timer() noexcept {
        __timer_task::__time_point __now = __timer_task::__clock::now();
        __timer_task              *__t   = __timer_heap_._M_top();
        while (__t != nullptr && !(__now < __t->__key_.__deadline_)) {
            __timer_heap_._M_pop();
            __t->__fire_(__t);
            __t = __timer_heap_._M_top();
        }
    }

    [[__nodiscard__]] auto _M_has_work() const noexcept -> bool {
        // Includes the cross-thread request queues: a coroutine resumed during
        // this iteration may have enqueued the next io/timer there, and it must
        // not be lost when the driver decides whether to keep looping.
        return __n_total_submitted_ > 0 || !__pending_._M_empty() ||
               __timer_heap_._M_top() != nullptr || !__requests_._M_empty() ||
               !__timer_requests_._M_empty();
    }

    // One driver iteration: flush io and timer commands, enter the kernel
    // waiting for at least `__min_complete` events (bounded by the earliest
    // pending timer), then reap completions and fire elapsed timers. Returns
    // true while work remains. Driver thread only.
    auto _M_run_once(unsigned __min_complete = 1) -> bool {
    __run_once_start:
        _M_drain_io_task();
        _M_drain_generic_timer_task();
        _M_fire_expired_timer();
        if (!_M_has_work()) { return false; }
        // Bound the wait by the earliest pending timer, expressed as a relative
        // timeout carried through io_uring_enter's extended argument -- no
        // kernel-side timer object is created.
        __kernel_timespec __ts{};
        bool              __have_timeout = false;
        if (__timer_task *__top = __timer_heap_._M_top()) {
            __ts = _S_duration_to_timespec(
                __top->__key_.__deadline_ - __timer_task::__clock::now());
            __have_timeout = true;
        }
        // Decide whether to block. Transition _S_loop -> _S_sleep so that a
        // concurrent `_M_submit`/`_M_submit_timer` either observes _S_sleep
        // (and wakes us via the eventfd) or has already flipped us to _S_notify
        // (CAS fails -> don't block, fold the new request next iteration). This
        // closes the lost-wakeup window between flush and io_uring_enter.
        unsigned         __wait     = __min_complete;
        _Sg              __expected = _Sg::_S_loop;
        std::unique_lock __lock{__fence_mut_};
        if (!__state_.compare_exchange_strong(
                __expected, _Sg::_S_sleep, std::memory_order_acq_rel)) {
            __lock.unlock();
            goto __run_once_start; // NOLINT
        }

        const auto __submit = static_cast<unsigned>(__n_newly_submitted_);
        int        __rc;
        if (__have_timeout) {
            io_uring_getevents_arg __arg{};
            __arg.ts = std::bit_cast<__u64>(&__ts);
            __lock.unlock();
            __rc = _S_io_uring_enter(
                __ring_fd_.__fd_, __submit, __wait,
                IORING_ENTER_GETEVENTS | IORING_ENTER_EXT_ARG, &__arg,
                sizeof(__arg));
        } else {
            __lock.unlock();
            __rc = _S_io_uring_enter(
                __ring_fd_.__fd_, __submit, __wait, IORING_ENTER_GETEVENTS);
        }
        __state_.store(_Sg::_S_loop, std::memory_order_relaxed);
        _S_throw_error_code_if(
            __rc < 0 && __rc != -EINTR && __rc != -ETIME, -__rc);
        if (__rc == -ETIME) {
            // The wait timed out; SUBMIT_ALL guarantees every queued SQE was
            // submitted before the kernel began waiting.
            __n_newly_submitted_ = 0;
        } else if (__rc != -EINTR) {
            assert(__rc <= __n_newly_submitted_);
            __n_newly_submitted_ -= __rc;
        }
        _M_complete();
        _M_fire_expired_timer();
        return _M_has_work();
    }

    // --- registration ------------------------------------------------------

    void _M_register_files(const int *__fds, unsigned __n) {
        _S_throw_error_code_if(
            _S_io_uring_register(
                __ring_fd_.__fd_, IORING_REGISTER_FILES,
                const_cast<int *>(__fds), __n) < 0,
            errno);
    }

    void _M_unregister_files() noexcept {
        (void)_S_io_uring_register(
            __ring_fd_.__fd_, IORING_UNREGISTER_FILES, nullptr, 0);
    }

    void _M_register_buffers(const ::iovec *__iov, unsigned __n) {
        const int __rc = _S_io_uring_register(
            __ring_fd_.__fd_, IORING_REGISTER_BUFFERS,
            const_cast<::iovec *>(__iov), __n);
        _S_throw_error_code_if(__rc < 0, -__rc);
    }

    void _M_unregister_buffers() noexcept {
        (void)_S_io_uring_register(
            __ring_fd_.__fd_, IORING_UNREGISTER_BUFFERS, nullptr, 0);
    }

    // Create a provided-buffer ring for multishot recv. `__base` points at
    // `__entries` contiguous buffers of `__buf_size` bytes each; `__entries`
    // must be a power of two.
    auto _M_make_buffer_ring(
        __u16 __bgid, void *__base, std::size_t __buf_size, __u16 __entries)
        -> __provided_buffer_ring {
        __provided_buffer_ring __r;
        __r._M_init(__ring_fd_.__fd_, __bgid, __base, __buf_size, __entries);
        return __r;
    }

  private:
    friend struct __schedule_after_operation;
    friend struct __wakeup_operation;

    // Driver run-state, used to coordinate cross-thread wakeups cheaply.
    enum class _Sg : unsigned char {
        _S_loop,   // driver is spinning; a fresh request is seen on next flush
        _S_sleep,  // driver is blocked in io_uring_enter; wake via the eventfd
        _S_notify, // a request arrived; driver must not block this round
    };

    __completion_queue  __completion_queue_;
    __submission_queue  __submission_queue_;
    __task_queue        __pending_{};
    __atomic_task_queue __requests_{};
    __wakeup_operation  __wakeup_operation_;
    __timer_heap        __timer_heap_{};
    __atomic_task_queue __timer_requests_{};
    std::size_t         __timer_seq_         = 0;
    std::ptrdiff_t      __n_total_submitted_ = 0;
    std::ptrdiff_t      __n_newly_submitted_ = 0;
    std::atomic<_Sg>    __state_{_Sg::_S_loop};
    bool                __wakeup_armed_ = false;
    std::mutex          __fence_mut_;
};

inline void __wakeup_operation::__complete_(
    __io_task *__p, const ::io_uring_cqe &) noexcept {
    auto &__self = *static_cast<__wakeup_operation *>(__p);
    // Re-arm so subsequent wakeups keep interrupting the kernel wait. This runs
    // on the driver thread, so `_M_submit` sees `_S_loop` and writes no
    // eventfd.
    __self.__context_->_M_submit(&__self);
}

// The io_uring context, parameterised on the executor that owns coroutine
// resumption. The context submits io and dispatches completions; whenever an
// operation is ready to resume its awaiting coroutine it routes the handle
// through `__exec_` (see _M_dispatch / __executor). The executor is held by
// value with `[[no_unique_address]]` so an empty executor adds no storage.
struct __io_uring_context : public __io_uring_dispatch {
    __thread_scheduler __scheduler_;
    // The executor is default-constructed in place (so non-movable executors --
    // e.g. ones owning a worker thread, mutex or condvar -- are supported); use
    // `_M_executor()` to configure it afterwards. `_Args` forward to the
    // executor's constructor when it is not default-constructible / needs
    // setup.
    explicit __io_uring_context(unsigned __entries = 1024, unsigned __flags = 0)
        : __io_uring_dispatch(__entries, __flags) {}
};

} // namespace __ngr::inline __v0::__core
// NOLINTEND(*-vararg, *-special-member-functions)
