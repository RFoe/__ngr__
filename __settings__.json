    "[One Dark Pro Night Flat]": {
      "rules": {
        // bold declaration
        "type.declaration": {
          "bold": true
        },
        "class.declaration": {
          "bold": true
        },
        "function.declaration": {
          "bold": true
        },
        "method.declaration": {
          "bold": true
        },
        // a dedicated color for macro
        "macro": "#BEB7FF",
        // a dedicated color for global variables
        "variable.globalScope": "#C8C8C8",
        // italic parameters
        "parameter": {
          "italic": true
        },
        "typeParameter": {
          "italic": true
        },
        "property": {
          "italic": true
        },
        // color non-type template paramter as variable
        "typeParameter.readonly": {
          "foreground": "#9CDCFE",
        },
        // color deduced 'auto' consistently
        "*.deduced": "#569CD6",
        // color variable 
        // don't color differconsistentlyently on readonly modifier because of a clangd bug (maybe a feature)
        "variable.readonly.globalScope": "#C8C8C8",
        "variable.readonly.fileScope": "#C8C8C8",
        "property.readonly.classScope": "#9CDCFE",
        "variable.readonly.classScope": "#C8C8C8",
        "parameter.readonly.functionScope": "#9CDCFE",
        "variable.readonly.functionScope": "#9CDCFE",
        "variable.readonly.localScope": "#9CDCFE",
      }
    }
