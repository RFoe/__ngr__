#include <__ngr/__core/__circular_buffer.hpp>
#include <__ngr/__core/__memory_resource.hpp>
#include <__ngr/__core/__scheduler.hpp>
#include <__ngr/__core/__spawn.hpp>
#include <__ngr/__core/__task.hpp>

#include <arpa/inet.h>
#include <print>
#include <sys/socket.h>

#include <__algorithm/min.h>
#include <__vector/vector.h>

using namespace __ngr::__core; // NOLINT

namespace {

__scheduler __k_schd{1024, 0};
int         __k_accept = -1;

#define _LIBNGR_MAX_ACQ_ONCE 4U

template <auto __m, typename _Ty = __remove_cvref(decltype(__m))>
constexpr auto __div(_Ty __n) -> _Ty {
    return (__n + __m - 1) / __m;
}

template <typename _Ty> auto __async_spawn(_Ty) noexcept -> __spawn_task<_Ty> {
    co_return;
}

struct __async_receive : public __ioring_task {
    using __circular_block_buffer = __circular_buffer<__shared_block_subrange, 64>;
    int                     __rfd_;
    __u32                   __param_;
    __circular_block_buffer __buf_;
    ::iovec                 __iov_[8];
    ::msghdr                __msghdr_;
    __u32                   __M_  = 0;
    __u32                   __nv_ = 0;
    static void __submit(__ioring_task *__base, ::io_uring_sqe &__sqe) noexcept {
        auto *__op = static_cast<__async_receive *>(__base);
        __builtin_memset(&__sqe, 0, sizeof __sqe);
        __sqe.opcode    = IORING_OP_RECVMSG;
        __sqe.fd        = __op->__rfd_;
        __sqe.addr      = __builtin_bit_cast(__u64, &__op->__msghdr_);
        __sqe.len       = 1;
        __sqe.msg_flags = MSG_WAITALL;
    }
    static void __complete(__ioring_task *__base, const ::io_uring_cqe &__cqe) noexcept {
        auto *__op = static_cast<__async_receive *>(__base);
        std::println("__cqe.res {}", __cqe.res);
        __throw_error_code_if(__cqe.res < 0, -__cqe.res);
        __op->__M_ += __cqe.res;
        __op->_M_do_execute();
    }
    struct __await_resume_result {
        __circular_block_buffer::__monotonic_prefix_subrange __prefix_;
        __shared_block_subrange                              __suffix_;

        void _M_print() && noexcept {
            while (!__prefix_._M_empty()) {
                auto &__tmp = __prefix_._M_front();
                std::println("{}", std::string_view{__tmp._M_base(), __tmp.__len_});
                __release(__tmp);
                __prefix_._M_pop_front();
            }
            if (__suffix_.__source_ != nullptr) {
                std::println(
                    "{}", std::string_view{__suffix_._M_base(), __suffix_.__len_});
                __release(__suffix_);
            }
        }
    };

    __async_receive(int __fd) noexcept
        : __ioring_task(_nttp_<__submit>, _nttp_<__complete>), __rfd_(__fd) {}

    static void __suspend(__async_receive *__op) noexcept {
        std::println("__suspend __k_schd._M_submit(__op);");
        __k_schd._M_submit(__op);
    }
    auto await_ready() const noexcept -> bool {
        std::println("__M_ >= __param_ {}", __M_ >= __param_);
        return __M_ >= __param_;
    }
    auto await_suspend(std::coroutine_handle<> __coro) noexcept -> void {
        __u32 __acq = __param_ - __M_;
        __u32 __max = __div<_LIBNGR_MAX_ACQ_ONCE>(__acq);
        __nv_       = 0;
        do {
            __u32 __min = std::min(__max, __acq);
            std::println("__acquire {}", __min);
            __shared_block_subrange __blk = __acquire(__min);
            __buf_._M_push_back()         = __blk;
            __iov_[__nv_++] = {.iov_base = __blk._M_base(), .iov_len = __blk.__len_};
            __acq -= __min;
        } while (__acq > 0);
        __builtin_memset(&__msghdr_, 0, sizeof __msghdr_);
        __msghdr_.msg_iov    = __iov_;
        __msghdr_.msg_iovlen = __nv_;

        __task_facade::__resume_ = __coro;
        __task_facade::__register<&__suspend>(this);
    }
    auto await_resume() noexcept -> __await_resume_result {
        std::println("__M_ == __param_ {} {}", __M_, __param_);
        assert(__M_ == __param_);
        __M_ = 0;
        __await_resume_result __result;
        __result.__prefix_ = __buf_._M_consume_front_while(
            [&](__shared_block_subrange &__rng) noexcept -> bool {
                if (__rng.__len_ > __param_) {
                    __result.__suffix_ = __rng.__splice_prefix(__param_);
                    __param_           = 0;
                    return false;
                }
                __param_ -= __rng.__len_;
                return true;
            });
        assert(__param_ == 0);
        return __result;
    }
};

auto __receive_coro(int __rfd) noexcept -> __task<> {
    std::println("__receive_coro");
    __async_receive __recv{__rfd};
    while (true) {
        __recv.__param_ = 8;
        auto __result   = co_await __recv;
        std::move(__result)._M_print();
    }
    co_return;
};

struct __async_accept : public __ioring_task {
    ::sockaddr_storage __addr_{};
    ::socklen_t        __addrlen_ = sizeof(::sockaddr_storage);

    static void __submit(__ioring_task *__base, ::io_uring_sqe &__sqe) noexcept {
        auto *__op = static_cast<__async_accept *>(__base);
        __builtin_memset(&__sqe, 0, sizeof __sqe);
        __sqe.opcode       = IORING_OP_ACCEPT;
        __sqe.fd           = __k_accept;
        __sqe.addr         = __builtin_bit_cast(__u64, &__op->__addr_);
        __sqe.off          = __builtin_bit_cast(__u64, &__op->__addrlen_);
        __sqe.accept_flags = 0;
        __sqe.ioprio       = IORING_ACCEPT_MULTISHOT;
    }

    static void __complete(__ioring_task *__base, const ::io_uring_cqe &__cqe) noexcept {
        std::println("accept complete");
        auto *__op = static_cast<__async_accept *>(__base);
        __throw_error_code_if(__cqe.res < 0, -__cqe.res);
        __async_spawn(__receive_coro(__cqe.res)).__task_->_M_do_execute();
        if (!(__cqe.flags & IORING_CQE_F_MORE)) { __k_schd._M_submit(__op); }
    }

    __async_accept() noexcept : __ioring_task(_nttp_<__submit>, _nttp_<__complete>) {}
};

} // namespace

auto main() -> int {
    __k_accept = ::socket(AF_INET, SOCK_STREAM, 0);
    int __yes  = 1;
    ::setsockopt(__k_accept, SOL_SOCKET, SO_REUSEADDR, &__yes, sizeof __yes);
    ::sockaddr_in __addr{};
    __builtin_memset(&__addr, 0, sizeof __addr);
    __addr.sin_family      = AF_INET;
    __addr.sin_port        = htons(8888);
    __addr.sin_addr.s_addr = htonl(INADDR_ANY);
    ::bind(__k_accept, reinterpret_cast<const ::sockaddr *>(&__addr), sizeof __addr);
    ::listen(__k_accept, SOMAXCONN);

    __async_accept __accept;
    __k_schd._M_submit(&__accept);
    __k_schd._M_run_until_stop();
}
